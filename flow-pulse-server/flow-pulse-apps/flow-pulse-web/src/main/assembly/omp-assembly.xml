<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.2.0 http://maven.apache.org/xsd/assembly-2.2.0.xsd">
    <id>omp</id>
    <formats>
        <format>dir</format>
        <format>tar.gz</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    <dependencySets>
        <dependencySet>
            <outputDirectory>flowpulse-main/lib</outputDirectory>
            <useProjectArtifact>true</useProjectArtifact>
            <scope>runtime</scope>
            <excludes>
                <exclude>org.projectlombok:lombok</exclude>
                <exclude>uyun.whale:util-shell</exclude>
            </excludes>
        </dependencySet>
    </dependencySets>
    <fileSets>
        <fileSet>
            <directory>src/main/resources/bin</directory>
            <outputDirectory>flowpulse-main/bin</outputDirectory>
            <fileMode>755</fileMode>
            <lineEnding>unix</lineEnding>
            <includes>
                <include>*.sh</include>
            </includes>
        </fileSet>

        <fileSet>
            <directory>target/util-shell</directory>
            <outputDirectory>flowpulse-main/bin</outputDirectory>
            <fileMode>755</fileMode>
            <lineEnding>unix</lineEnding>
            <includes>
                <include>*</include>
            </includes>
        </fileSet>

        <fileSet>
            <directory>src/main/resources</directory>
            <outputDirectory>flowpulse-main/config</outputDirectory>
            <includes>
                <include>application*.yml</include>
            </includes>
        </fileSet>
        <!-- config/ 额外模板文件 -->
        <fileSet>
            <directory>src/main/resources/config</directory>
            <outputDirectory>flowpulse-main/config</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>

        <fileSet>
            <directory>src/main/resources/db</directory>
            <outputDirectory>flowpulse-main/config/db</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>

        <fileSet>
            <directory>src/main/resources/i18n</directory>
            <outputDirectory>flowpulse-main/config/i18n</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>

        <fileSet>
            <directory>data</directory>
            <outputDirectory>flowpulse-main/data</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>

        <fileSet>
            <directory>src/main/resources</directory>
            <outputDirectory>flowpulse-main</outputDirectory>
            <includes>
                <include>bootstrap.yml</include>
            </includes>
        </fileSet>
        <fileSet>
            <directory>D:\codex\FlowPulse\flow-pulse-fronted\build</directory>
            <outputDirectory>flowpulse-main/static</outputDirectory>
        </fileSet>
    </fileSets>
</assembly>
